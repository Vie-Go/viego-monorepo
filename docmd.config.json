{
  "title": "Vibeat — Project Documentation",
  "url": "https://docs.vibeat.app",
  "src": "docs",
  "out": "site",
  "engine": "js",
  "layout": {
    "spa": true,
    "header": {
      "enabled": true
    },
    "sidebar": {
      "collapsible": true,
      "defaultCollapsed": false
    },
    "optionsMenu": {
      "position": "sidebar-top",
      "components": {
        "search": true,
        "themeSwitch": true
      }
    },
    "footer": {
      "style": "minimal",
      "content": "© 2026 Vie-Go — Vibeat.",
      "branding": true
    }
  },
  "theme": {
    "name": "default",
    "appearance": "system",
    "codeHighlight": true
  },
  "minify": true,
  "autoTitleFromH1": true,
  "copyCode": true,
  "pageNavigation": true,
  "navigation": [
    { "title": "Overview", "path": "/", "icon": "home" },
    {
      "title": "1.1.1 Core Specifications",
      "icon": "file-text",
      "collapsible": true,
      "children": [
        { "title": "Overview", "path": "/01-product-documentation/01-core-specifications", "icon": "book-open" },
        { "title": "API / System Specifications", "path": "/01-product-documentation/01-core-specifications/api-system-specifications", "icon": "plug" },
        { "title": "Canonical Data Schemas", "path": "/01-product-documentation/01-core-specifications/api-system-specifications/data-schemas", "icon": "database" },
        { "title": "Executable Specifications (BDD)", "path": "/01-product-documentation/01-core-specifications/executable-specifications", "icon": "check-circle" }
      ]
    },
    {
      "title": "1.1.2 Architecture (SAD)",
      "icon": "layers",
      "collapsible": true,
      "children": [
        { "title": "Overview", "path": "/01-product-documentation/02-authored-system-documentation/software-architecture-document", "icon": "book-open" },
        { "title": "Architecture Principles", "path": "/01-product-documentation/02-authored-system-documentation/software-architecture-document/architecture-principles", "icon": "shield" },
        { "title": "DDD & Domain Model", "path": "/01-product-documentation/02-authored-system-documentation/software-architecture-document/ddd-and-domain-model", "icon": "compass" },
        { "title": "Backend — Modular Monolith", "path": "/01-product-documentation/02-authored-system-documentation/software-architecture-document/backend-modular-monolith", "icon": "server" },
        { "title": "Service Extraction Playbook", "path": "/01-product-documentation/02-authored-system-documentation/software-architecture-document/service-extraction-playbook", "icon": "git-branch" },
        { "title": "Frontend Architecture", "path": "/01-product-documentation/02-authored-system-documentation/software-architecture-document/frontend-architecture", "icon": "smartphone" },
        { "title": "Detailed Design (per module)", "path": "/01-product-documentation/02-authored-system-documentation/software-architecture-document/design", "icon": "boxes" },
        { "title": "· Identity (Authentication)", "path": "/01-product-documentation/02-authored-system-documentation/software-architecture-document/design/identity", "icon": "key" },
        { "title": "· Exploration (Unlocking)", "path": "/01-product-documentation/02-authored-system-documentation/software-architecture-document/design/exploration", "icon": "map-pin" },
        { "title": "· Engagement (Streaks)", "path": "/01-product-documentation/02-authored-system-documentation/software-architecture-document/design/engagement", "icon": "flame" },
        { "title": "· Content (Heritage)", "path": "/01-product-documentation/02-authored-system-documentation/software-architecture-document/design/content", "icon": "music" },
        { "title": "Infrastructure", "path": "/01-product-documentation/02-authored-system-documentation/software-architecture-document/infrastructure", "icon": "cloud" },
        { "title": "Decisions (ADRs)", "path": "/01-product-documentation/02-authored-system-documentation/software-architecture-document/decisions", "icon": "git-commit" }
      ]
    },
    {
      "title": "1.1.2 UX Design",
      "icon": "palette",
      "collapsible": true,
      "children": [
        { "title": "Overview", "path": "/01-product-documentation/02-authored-system-documentation/ux-design-documentation", "icon": "book-open" },
        { "title": "Design System", "path": "/01-product-documentation/02-authored-system-documentation/ux-design-documentation/design-system", "icon": "swatch" },
        { "title": "Localization", "path": "/01-product-documentation/02-authored-system-documentation/ux-design-documentation/localization", "icon": "languages" }
      ]
    },
    {
      "title": "1.1.3 Generated Artifacts",
      "icon": "file-code",
      "collapsible": true,
      "children": [
        { "title": "Overview", "path": "/01-product-documentation/03-generated-system-artifacts", "icon": "book-open" },
        { "title": "API Reference", "path": "/01-product-documentation/03-generated-system-artifacts/api-reference-documentation", "icon": "book" },
        { "title": "Source Code Models", "path": "/01-product-documentation/03-generated-system-artifacts/source-code-models", "icon": "code" },
        { "title": "QA Reports", "path": "/01-product-documentation/03-generated-system-artifacts/quality-assurance-reports", "icon": "clipboard-check" }
      ]
    },
    {
      "title": "1.1.4 User Documentation",
      "icon": "users",
      "collapsible": true,
      "children": [
        { "title": "Overview", "path": "/01-product-documentation/04-user-documentation", "icon": "book-open" },
        { "title": "End-user", "path": "/01-product-documentation/04-user-documentation/end-user-documentation", "icon": "user" },
        { "title": "Developer Integration", "path": "/01-product-documentation/04-user-documentation/developer-integration-guides", "icon": "terminal" },
        { "title": "System Admin", "path": "/01-product-documentation/04-user-documentation/system-admin-documentation", "icon": "settings" }
      ]
    },
    {
      "title": "1.2 Process Documentation",
      "icon": "list-checks",
      "collapsible": true,
      "children": [
        { "title": "Overview", "path": "/02-process-documentation", "icon": "book-open" },
        { "title": "Roadmaps & Backlogs", "path": "/02-process-documentation/roadmaps-and-backlogs", "icon": "map" },
        { "title": "SDD Standards", "path": "/02-process-documentation/sdd-standards", "icon": "ruler" },
        { "title": "Plans, Estimates, Schedules", "path": "/02-process-documentation/plans-estimates-schedules", "icon": "calendar" },
        { "title": "Test Strategy", "path": "/02-process-documentation/test-strategy", "icon": "flask-conical" },
        { "title": "Release Checklist", "path": "/02-process-documentation/release-checklist", "icon": "rocket" },
        { "title": "Reports", "path": "/02-process-documentation/reports", "icon": "bar-chart" }
      ]
    },
    { "title": "GitHub", "path": "https://github.com/vie-go/vibeat", "icon": "github", "external": true }
  ],
  "plugins": {
    "git": {
      "commitHistory": true,
      "maxCommits": 5
    },
    "seo": {
      "defaultDescription": "Vibeat project documentation — Spring Boot / Java 25 backend, React Native mobile, SDD + DDD."
    }
  }
}
